# .env.example — CurationsX YOLO / foundry-sim
#
# Variable NAMES only. No values. No secrets.
# Copy to .env and fill in your own values for local development.
# Never commit a .env file with real values.
#
# See docs/PRD-azure-foundry-integration.md for full documentation.

# ── Foundry simulator (active mode — no Azure required) ──────────────────────

# Controls which mode the FoundryClient uses.
#   sim   = local offline emulator (default; no network, no cost)
#   azure = real Azure OpenAI integration (NOT enabled in this build — see PRD)
FOUNDRY_MODE=sim

# Persona profile hint for the simulator.
#   auto = no pinned model; routes to Copilot auto engine (default)
SIM_PROFILE=auto

# ── Azure OpenAI (future real integration — NOT enabled in this build) ────────
# Set these only when FOUNDRY_MODE=azure and you have read PRD-azure-foundry-integration.md

# Full Azure OpenAI endpoint URL.
# Example: https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# Deployment name — MUST be a first-party Azure OpenAI deployment.
# Third-party / Marketplace deployments are blocked by the allowlist.
# Example: gpt-4o
AZURE_OPENAI_DEPLOYMENT=

# Azure OpenAI REST API version.
# Example: 2024-02-01
AZURE_OPENAI_API_VERSION=

# ── Azure Entra ID auth (preferred — no secret in code) ─────────────────────
# Client ID for a user-assigned managed identity (optional).
# DefaultAzureCredential works without this in most environments.
AZURE_CLIENT_ID=

# ── API key fallback (local dev only — prefer DefaultAzureCredential) ────────
# DO NOT commit a real key. Use only for local development without managed identity.
AZURE_OPENAI_API_KEY=
