---
import { withBase } from '../lib/labels';

interface Props {
  fixtureEnabled: boolean;
  publicProfilePath?: string;
}

const {
  fixtureEnabled,
  publicProfilePath = '/members/curationsla/',
} = Astro.props;
const apiBase = import.meta.env.PUBLIC_AGENT_API ?? '';
---

<div
  class="member-private-gate"
  data-member-private-gate
  data-api={apiBase}
  data-fixture-enabled={fixtureEnabled ? 'true' : 'false'}
>
  <section class="member-sign-in-gate" data-member-signed-out>
    <p class="discovery-eyebrow">Private member workspace</p>
    <h1>Sign in with GitHub to continue.</h1>
    <p>
      GitHub proves identity. Your CURATIONS profile, settings, drafts, and Inbox
      remain separate from your external GitHub profile.
    </p>
    <div class="member-gate-actions">
      <button class="community-action community-action-primary" type="button" data-member-sign-in>
        Sign in with GitHub
      </button>
      <a class="community-action" href={withBase(publicProfilePath)}>View public profile</a>
    </div>
    <p class="field-help" data-member-gate-status aria-live="polite">
      Checking CURATIONS identity…
    </p>
  </section>

  <div data-member-private-content hidden>
    <slot />
  </div>
</div>

<script>
  import {
    beginGithubSignIn,
    currentUser,
    getSessionToken,
    type AuthUser,
  } from '../lib/browser-auth';

  for (const root of document.querySelectorAll<HTMLElement>('[data-member-private-gate]')) {
    const api = root.dataset.api ?? '';
    const fixtureEnabled = root.dataset.fixtureEnabled === 'true';
    const signedOut = root.querySelector<HTMLElement>('[data-member-signed-out]')!;
    const content = root.querySelector<HTMLElement>('[data-member-private-content]')!;
    const signIn = root.querySelector<HTMLButtonElement>('[data-member-sign-in]')!;
    const status = root.querySelector<HTMLElement>('[data-member-gate-status]')!;

    const showSignedOut = (message: string): void => {
      signedOut.hidden = false;
      content.hidden = true;
      signIn.disabled = !api;
      status.textContent = message;
    };

    const showContent = (): void => {
      signedOut.hidden = true;
      content.hidden = false;
    };

    const fixtureAuth =
      fixtureEnabled &&
      new URLSearchParams(window.location.search).get('fixture_auth') === '1';

    signIn.addEventListener('click', () => {
      if (api) beginGithubSignIn(api);
    });

    document.addEventListener('curations:auth', (event) => {
      const detail = (event as CustomEvent<{ user: AuthUser | null }>).detail;
      if (detail?.user) showContent();
      else if (!fixtureAuth) showSignedOut('');
    });

    if (fixtureAuth) {
      showContent();
      continue;
    }
    if (!api) {
      showSignedOut('Identity gateway unavailable in this environment.');
      continue;
    }
    if (!getSessionToken()) {
      showSignedOut('GitHub identity is required for this private route.');
      continue;
    }

    try {
      const user = await currentUser(api);
      if (user) showContent();
      else showSignedOut('Your CURATIONS session expired. Sign in again.');
    } catch {
      showSignedOut('Identity is temporarily unavailable. Try again.');
    }
  }
</script>
