---
/**
 * EngagePanel — the two-lane conversation surface on a tool landing page.
 *
 *   Lane A "Will this work for me?" — visitor describes their PRD, the
 *   company-grounded persona assesses fit and suggests PRD improvements.
 *   Lane B "Community" — visitor shares how they use the tool or a prompt
 *   they curated; the persona responds with encouragement + one gotcha.
 *
 * Talks to the CURATIONS agent gateway (Cloudflare Worker). The gateway
 * holds all keys and enforces all caps — this component is plain HTML+JS.
 */
interface Props {
  toolId: string;
  toolName: string;
  personaName: string;
  disclosure: string;
  groundingNote: string;
}
const { toolId, toolName, personaName, disclosure, groundingNote } = Astro.props;
const apiBase = import.meta.env.PUBLIC_AGENT_API ?? "";
const messageId = `engage-message-${toolId}`;
const privacyId = `engage-privacy-${toolId}`;
---

<section class="engage" data-tool={toolId} data-api={apiBase}>
  <h2>Ask {personaName}</h2>
  <p class="engage-disclosure">🤖 {disclosure}<br /><span class="muted">{groundingNote}</span></p>

  <div class="lane-tabs" role="tablist" aria-label="Conversation lanes">
    <button type="button" role="tab" aria-selected="true" data-lane="prd-check">
      Will {toolName} work for me?
    </button>
    <button type="button" role="tab" aria-selected="false" data-lane="community">
      Share how you use it
    </button>
  </div>

  <form class="engage-form">
    <label class="engage-label" data-for-lane="prd-check" for={messageId}>
      Describe your product or PRD — {personaName} will assess the fit and suggest tuning.
    </label>
    <label class="engage-label" data-for-lane="community" for={messageId} hidden>
      Share your setup, workflow, or a prompt you curated — {personaName} will respond,
      and your post joins the public feed below.
    </label>
    <textarea
      id={messageId}
      name="message"
      rows="5"
      maxlength="4000"
      aria-describedby={privacyId}
      required
      placeholder="Keep it concrete — stack, goal, constraint…"></textarea>
    <div class="engage-row">
      <label class="check-row engage-publish">
        <input type="checkbox" name="publish" />
        <span data-publish-label>Publish this exchange to the company board</span>
      </label>
      <button type="submit" class="btn btn-primary">Send</button>
    </div>
    <p id={privacyId} class="engage-privacy muted" data-engage-privacy>
      Private by default. Unpublished PRD checks are answered and not stored.
    </p>
    <p class="engage-status" role="status" aria-live="polite"></p>
  </form>

  <div class="engage-reply" hidden>
    <p class="engage-reply-head">
      <strong class="reply-persona"></strong>
      <span class="badge badge-ai">AI persona</span>
    </p>
    <div class="engage-reply-body"></div>
  </div>
</section>

<script>
  import {
    authHeaders,
    beginGithubSignIn,
    getSessionToken,
  } from '../lib/browser-auth';

  for (const root of document.querySelectorAll<HTMLElement>(".engage")) {
    const api = root.dataset.api ?? "";
    const tool = root.dataset.tool ?? "";
    const form = root.querySelector("form")!;
    const status = root.querySelector<HTMLElement>(".engage-status")!;
    const replyBox = root.querySelector<HTMLElement>(".engage-reply")!;
    const replyPersona = root.querySelector<HTMLElement>(".reply-persona")!;
    const replyBody = root.querySelector<HTMLElement>(".engage-reply-body")!;
    const publish = root.querySelector<HTMLInputElement>('input[name="publish"]')!;
    const publishLabel = root.querySelector<HTMLElement>('[data-publish-label]')!;
    const privacy = root.querySelector<HTMLElement>('[data-engage-privacy]')!;
    let lane = "prd-check";
    let requestId = crypto.randomUUID();

    const renderLane = (): void => {
      const isCommunity = lane === 'community';
      publish.checked = isCommunity;
      publish.disabled = isCommunity;
      publishLabel.textContent = isCommunity
        ? 'Publish this community share'
        : 'Publish this exchange to the company board';
      privacy.textContent = isCommunity
        ? 'Community shares are public and require GitHub sign-in.'
        : 'Private by default. Unpublished PRD checks are answered and not stored.';
    };

    for (const tab of root.querySelectorAll<HTMLButtonElement>("[data-lane]")) {
      tab.addEventListener("click", () => {
        lane = tab.dataset.lane!;
        for (const t of root.querySelectorAll<HTMLButtonElement>("[data-lane]")) {
          t.setAttribute("aria-selected", String(t === tab));
        }
        for (const label of root.querySelectorAll<HTMLElement>(".engage-label")) {
          label.hidden = label.dataset.forLane !== lane;
        }
        renderLane();
      });
    }
    renderLane();

    form.addEventListener("submit", async (ev) => {
      ev.preventDefault();
      if (!api) {
        status.textContent = "The agent gateway is not configured for this build yet.";
        return;
      }
      const shouldPublish = lane === 'community' || publish.checked;
      if (shouldPublish && !getSessionToken()) {
        beginGithubSignIn(api);
        return;
      }
      const data = new FormData(form);
      const btn = form.querySelector<HTMLButtonElement>("button[type=submit]")!;
      btn.disabled = true;
      status.textContent = "Asking…";
      replyBox.hidden = true;
      try {
        const res = await fetch(`${api}/api/ask`, {
          method: "POST",
          headers: { "content-type": "application/json", ...authHeaders() },
          body: JSON.stringify({
            tool_id: tool,
            lane,
            message: data.get("message"),
            publish: shouldPublish,
            request_id: requestId,
          }),
        });
        const body = await res.json();
        if (res.status === 401) {
          beginGithubSignIn(api);
          return;
        }
        if (!res.ok) {
          status.textContent = body.error ?? "Something went wrong.";
          return;
        }
        status.textContent = "";
        replyPersona.textContent = body.persona;
        replyBody.textContent = body.reply;
        replyBox.hidden = false;
        if (body.published) {
          document.dispatchEvent(new CustomEvent("curations:engagement", { detail: { tool } }));
        }
        requestId = crypto.randomUUID();
      } catch {
        status.textContent = "Network error — try again in a moment.";
      } finally {
        btn.disabled = false;
      }
    });
  }
</script>
