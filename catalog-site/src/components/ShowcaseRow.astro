---
import type { ShowcaseFixture } from '../data/member-showcase-preview';
import { withBase } from '../lib/labels';
import ShowcaseStatusPill from './ShowcaseStatusPill.astro';
import StackPill from './StackPill.astro';

interface Props {
  showcase: ShowcaseFixture;
}

const { showcase } = Astro.props;
---

<article class="project-row showcase-row" data-showcase-row>
  <div class="project-score" aria-label={`${showcase.score} conversation votes`}>
    <span aria-hidden="true">▲</span>
    <strong>{showcase.score}</strong>
  </div>
  <div class="project-row-main">
    <header class="project-row-heading">
      <a
        class="project-question"
        data-showcase-question
        href={withBase(`/showcase/${showcase.slug}/`)}
      >
        “{showcase.question}”
      </a>
      <ShowcaseStatusPill kind="showcase" />
      {
        showcase.roastCount > 0
          ? <ShowcaseStatusPill kind="roasted" />
          : showcase.roastOpen && <ShowcaseStatusPill kind="open-roast" />
      }
    </header>
    <p class="project-identity">
      <a
        class="project-repository-link"
        data-showcase-title
        data-showcase-source
        href={showcase.prdUrl}
        target="_blank"
        rel="noopener"
        aria-label={`${showcase.title} public PRD`}
      >
        {showcase.title}<span aria-hidden="true"> ↗</span>
      </a>
      <span aria-hidden="true">·</span>
      shared by
      <a
        class="project-author showcase-author"
        href={withBase(`/members/${showcase.author.login.toLowerCase()}/`)}
      >
        @{showcase.author.login}
      </a>
    </p>
    <p class="project-summary" data-showcase-purpose>{showcase.purpose}</p>
    <div class="project-context">
      <a
        class="project-plan-label"
        href={withBase(`/showcase/${showcase.slug}/#breakdown`)}
      >
        AI-assisted purpose breakdown
      </a>
      {showcase.stackSlugs.map((stackSlug) => <StackPill slug={stackSlug} />)}
    </div>
    <footer class="project-meta">
      <span>{showcase.comments} replies</span>
      <span aria-hidden="true">·</span>
      <span>{showcase.people} people</span>
      {showcase.roastOpen && (
        <>
          <span aria-hidden="true">·</span>
          <span class="showcase-roast-open-copy">open for Roast</span>
        </>
      )}
      <span aria-hidden="true">·</span>
      <time>{showcase.age}</time>
    </footer>
  </div>
</article>
