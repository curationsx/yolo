---
import { showcaseFixture } from '../data/member-showcase-preview';
import ShowcaseRow from './ShowcaseRow.astro';

const previewShowcase = {
  ...showcaseFixture,
  score: 0,
  roastCount: 0,
  comments: 0,
  people: 1,
  age: 'fixture preview',
};

const copilotPromptTemplate = `Review the public PRD at the exact URL below.

Public PRD URL: {{PRD_URL}}
Source revision: {{SOURCE_REVISION}}

Return only this structure:
PRD title:
Purpose in one sentence:
Problem:
Who it is for:
What the proposed product does:
Key decisions already made:
Important non-goals:
Stacks or tools explicitly named:
Open decisions:
Best first discussion question:
Source PRD URL:
Source revision:

Separate facts from assumptions. Do not inspect private files, .env files,
credentials, terminal history, or unrelated repository content.`;
const copilotPrompt = copilotPromptTemplate
  .replace('{{PRD_URL}}', showcaseFixture.prdUrl)
  .replace('{{SOURCE_REVISION}}', showcaseFixture.sourceRevision);
const initialBreakdown = `PRD title: ${showcaseFixture.title}
Purpose in one sentence: ${showcaseFixture.breakdown.purpose}
Problem: ${showcaseFixture.breakdown.problem}
Who it is for: ${showcaseFixture.breakdown.audience}
What the proposed product does: ${showcaseFixture.breakdown.product}
Key decisions already made: GitHub proves identity; Showcase can exist without full Project intake; the human question remains first; the breakdown is context, not verification; Roast consent never invites a hosted agent.
Important non-goals: Repository crawling, hosted execution, automatic publication, unrestricted private messages, follower scores, and quality grades.
Stacks or tools explicitly named: GitHub Copilot CLI.
Open decisions: Minimum persisted profile; when a Showcase becomes a Project; safety controls required before a real Roast.
Best first discussion question: ${showcaseFixture.question}
Source PRD URL: ${showcaseFixture.prdUrl}
Source revision: ${showcaseFixture.sourceRevision}`;
---

<div
  class="project-builder-shell showcase-builder-shell"
  data-showcase-builder
  data-showcase-owner={showcaseFixture.author.login}
>
  <p class="community-preview-note">
    Fixture-only Showcase journey · no repository read, CLI invocation, publication, or model call
  </p>

  <ol class="form-steps" aria-label="PRD Showcase preview progress">
    <li data-showcase-step-indicator="0" aria-current="step"><span>01</span> Public source</li>
    <li data-showcase-step-indicator="1"><span>02</span> CLI breakdown</li>
    <li data-showcase-step-indicator="2"><span>03</span> Conversation</li>
    <li data-showcase-step-indicator="3"><span>04</span> Exact preview</li>
  </ol>
  <p class="visually-hidden" data-showcase-step-status aria-live="polite"></p>

  <form class="submission-form project-builder-form" data-showcase-builder-form>
    <fieldset data-showcase-step="0">
      <legend data-showcase-step-title tabindex="-1">
        Anchor the Showcase to one public PRD.
      </legend>
      <p class="project-builder-step-copy">
        The pilot requires an exact, commit-pinned Markdown PRD in a personal
        public GitHub repository owned by the signed-in member.
      </p>
      <div class="field-grid">
        <label class="field-span">
          Exact public PRD URL
          <input
            type="url"
            name="prd_url"
            required
            value={showcaseFixture.prdUrl}
          />
          <span class="field-help">
            Use a GitHub Markdown blob URL pinned to its full 40-character commit SHA.
            This fixture compares the URL owner locally; it makes no GitHub request.
          </span>
        </label>
        <label>
          Source revision
          <input
            name="source_revision"
            required
            maxlength="120"
            value={showcaseFixture.sourceRevision}
          />
        </label>
        <label>
          PRD title
          <input
            name="showcase_title"
            required
            maxlength="100"
            value={showcaseFixture.title}
          />
        </label>
        <label class="check-row field-span showcase-confirmation">
          <input type="checkbox" name="ownership" required />
          I am signed in as the personal GitHub account that owns this public repository.
        </label>
        <label class="check-row field-span showcase-confirmation">
          <input type="checkbox" name="sensitive_content_removed" required />
          I removed secrets, personal data, customer records, and confidential material.
        </label>
      </div>
    </fieldset>

    <fieldset data-showcase-step="1" hidden>
      <legend data-showcase-step-title tabindex="-1">
        Create the required purpose breakdown.
      </legend>
      <p class="project-builder-step-copy">
        Run this versioned prompt in your own GitHub Copilot CLI. CURATIONS does
        not start the CLI or receive its transcript.
      </p>
      <div class="showcase-cli-prompt">
        <header>
          <span>prd-showcase-purpose/0.1</span>
          <button class="community-action" type="button" data-copy-showcase-prompt>
            Copy prompt
          </button>
        </header>
        <pre><code data-showcase-prompt-template={copilotPromptTemplate}>{copilotPrompt}</code></pre>
        <p data-showcase-copy-status aria-live="polite"></p>
      </div>
      <label>
        Copilot CLI output
        <textarea name="breakdown" required minlength="80" rows="12">{initialBreakdown}</textarea>
      </label>
      <label>
        Author-approved purpose in one sentence
        <textarea name="purpose" required minlength="20" maxlength="260" rows="3">{showcaseFixture.purpose}</textarea>
      </label>
      <label class="check-row showcase-confirmation">
        <input type="checkbox" name="breakdown_approved" required />
        I reviewed this AI-assisted breakdown and approve the public wording.
      </label>
    </fieldset>

    <fieldset data-showcase-step="2" hidden>
      <legend data-showcase-step-title tabindex="-1">
        Ask one useful human question.
      </legend>
      <p class="project-builder-step-copy">
        Self-promotion is welcome when it includes public source, purpose, and a
        real discussion question.
      </p>
      <label>
        Discussion question
        <textarea name="question" required minlength="12" maxlength="220" rows="3">{showcaseFixture.question}</textarea>
      </label>
      <div class="field-grid">
        <label>
          Review mode
          <select name="review_mode">
            <option selected>Discussion</option>
            <option>Focused review</option>
          </select>
        </label>
        <fieldset class="platform-field">
          <legend>Stack context</legend>
          <div class="choice-grid">
            <label class="check-row"><input type="checkbox" name="showcase_stack" value="astro" checked /> Astro</label>
            <label class="check-row"><input type="checkbox" name="showcase_stack" value="typescript" checked /> TypeScript</label>
            <label class="check-row"><input type="checkbox" name="showcase_stack" value="github" checked /> GitHub Actions</label>
          </div>
        </fieldset>
      </div>
      <label class="check-row showcase-roast-choice">
        <input type="checkbox" name="roast_open" />
        Open this PRD to a Rubber Duck Roast
      </label>
      <p class="field-help">
        Structured critique of the artifact only. This does not invite a hosted AI.
      </p>
      <label class="check-row showcase-agent-choice">
        <input type="checkbox" name="invite_agent" disabled />
        Invite a hosted AI Rubber Duck (separate future control)
      </label>
    </fieldset>

    <fieldset data-showcase-step="3" hidden>
      <legend data-showcase-step-title tabindex="-1">
        Preview exactly what would become public.
      </legend>
      <p class="project-builder-step-copy">
        The required breakdown is author-approved context, not independent
        verification. This fixture cannot publish.
      </p>
      <section class="project-public-preview showcase-public-preview">
        <header class="project-preview-heading">
          <span>Shared Active feed + Showcase master</span>
          <strong>Human question first</strong>
        </header>
        <ShowcaseRow showcase={previewShowcase} />
        <section class="showcase-exact-preview" aria-label="Exact Showcase detail preview">
          <header>
            <p class="discovery-eyebrow">AI-assisted purpose breakdown</p>
            <strong>Builder-approved context</strong>
          </header>
          <p class="showcase-disclosure">
            Generated in the author’s GitHub Copilot CLI · reviewed and approved by
            the author · not independent verification
          </p>
          <pre data-showcase-breakdown>{initialBreakdown}</pre>
          <dl class="showcase-preview-facts">
            <div>
              <dt>Exact public source</dt>
              <dd>
                <a
                  data-showcase-source
                  href={showcaseFixture.prdUrl}
                  target="_blank"
                  rel="noopener"
                >
                  Read commit-pinned PRD ↗
                </a>
              </dd>
            </div>
            <div>
              <dt>Source revision</dt>
              <dd data-showcase-source-revision>{showcaseFixture.sourceRevision}</dd>
            </div>
            <div>
              <dt>Review mode</dt>
              <dd data-showcase-review-mode>Discussion</dd>
            </div>
            <div>
              <dt>Roast consent</dt>
              <dd data-showcase-roast-summary>Not open for Roast</dd>
            </div>
          </dl>
        </section>
      </section>
      <section class="project-builder-consent">
        <p class="discovery-eyebrow">Explicit publication boundary</p>
        <label class="check-row">
          <input type="checkbox" name="showcase_consent" required />
          I reviewed this exact Showcase preview and want to send it to maintainer review.
        </label>
        <button
          class="community-action community-action-primary"
          type="button"
          data-showcase-confirm
        >
          Send to maintainer review
        </button>
        <div data-showcase-pending class="project-builder-pending" hidden aria-live="polite">
          <strong>Pending review · fixture complete</strong>
          <p>No Showcase was created, no PRD was fetched, and no model was invoked.</p>
        </div>
      </section>
    </fieldset>

    <div class="submission-nav">
      <button class="community-action" type="button" data-showcase-back hidden>← Back</button>
      <button
        class="community-action community-action-primary"
        type="button"
        data-showcase-next
      >
        Continue →
      </button>
    </div>
  </form>
</div>

<script>
  import { initShowcaseBuilderJourneys } from './ShowcaseBuilderJourney';
  initShowcaseBuilderJourneys();
</script>
