---
/**
 * EngagementFeed — the public record of conversations on a landing page.
 * Fetches from the agent gateway's /api/feed endpoint client-side, so the
 * static build never goes stale. Every AI voice carries a visible label.
 */
interface Props {
  toolId: string;
  toolName: string;
}
const { toolId, toolName } = Astro.props;
const apiBase = import.meta.env.PUBLIC_AGENT_API ?? "";
---

<section class="feed" data-tool={toolId} data-api={apiBase}>
  <h2>Community feed</h2>
  <p class="muted feed-sub">
    How people are actually using {toolName} — PRD fit checks, workflows, and shared
    prompts. AI personas are always labeled.
  </p>
  <div class="feed-list" aria-live="polite">
    <p class="feed-empty muted">Loading the latest engagements…</p>
  </div>
</section>

<script>
  const LANE_LABELS: Record<string, string> = {
    "prd-check": "PRD fit check",
    community: "Community share",
  };

  function el(tag: string, className: string, text?: string): HTMLElement {
    const node = document.createElement(tag);
    node.className = className;
    if (text !== undefined) node.textContent = text;
    return node;
  }

  async function loadFeed(root: HTMLElement): Promise<void> {
    const api = root.dataset.api ?? "";
    const tool = root.dataset.tool ?? "";
    const list = root.querySelector<HTMLElement>(".feed-list")!;
    if (!api) {
      list.replaceChildren(
        el("p", "feed-empty muted", "Feed goes live once the agent gateway is deployed."),
      );
      return;
    }
    try {
      const res = await fetch(`${api}/api/feed?tool=${encodeURIComponent(tool)}&limit=20`);
      if (!res.ok) throw new Error(String(res.status));
      const body = (await res.json()) as {
        engagements: {
          id: string;
          lane: string;
          author_name: string;
          message: string;
          reply_display_name: string | null;
          reply_disclosure: string | null;
          reply_text: string | null;
          created_at: string;
        }[];
      };
      if (!body.engagements.length) {
        list.replaceChildren(
          el("p", "feed-empty muted", "No engagements yet — be the first to ask."),
        );
        return;
      }
      const items = body.engagements.map((e) => {
        const item = el("article", "feed-item");
        const head = el("p", "feed-item-head");
        head.append(
          el("strong", "", e.author_name),
          el("span", "badge", LANE_LABELS[e.lane] ?? e.lane),
          el("span", "muted feed-date", new Date(e.created_at).toLocaleDateString()),
        );
        item.append(head, el("p", "feed-message", e.message));
        if (e.reply_text) {
          const reply = el("div", "feed-reply");
          const rhead = el("p", "feed-item-head");
          rhead.append(
            el("strong", "", e.reply_display_name ?? "Persona"),
            el("span", "badge badge-ai", "AI persona"),
          );
          reply.append(rhead, el("p", "feed-message", e.reply_text));
          if (e.reply_disclosure) reply.append(el("p", "muted feed-disclosure", e.reply_disclosure));
          item.append(reply);
        }
        return item;
      });
      list.replaceChildren(...items);
    } catch {
      list.replaceChildren(
        el("p", "feed-empty muted", "Feed is unavailable right now — try again shortly."),
      );
    }
  }

  for (const root of document.querySelectorAll<HTMLElement>(".feed")) {
    loadFeed(root);
    document.addEventListener("curations:engagement", (ev) => {
      if ((ev as CustomEvent).detail?.tool === root.dataset.tool) {
        setTimeout(() => loadFeed(root), 800);
      }
    });
  }
</script>
