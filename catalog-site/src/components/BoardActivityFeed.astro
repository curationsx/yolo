---
interface FeedTool {
  id: string;
  name: string;
}

interface Props {
  tools: FeedTool[];
}

const { tools } = Astro.props;
const apiBase = import.meta.env.PUBLIC_AGENT_API ?? '';
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<aside
  id="universal-feed"
  class="board-feed"
  data-board-activity
  data-api={apiBase}
  data-base={basePath}
  data-tools={JSON.stringify(tools)}
>
  <h2>Universal feed</h2>
  <div class="board-feed-list" data-board-activity-list aria-live="polite">
    <p class="board-feed-empty">Loading public Board activity…</p>
  </div>
  <p class="board-feed-disclosure">
    AI contributions always labeled · public actions require GitHub identity
  </p>
</aside>

<script>
  import { initBoardActivityFeeds } from './BoardActivityFeed';
  void initBoardActivityFeeds();
</script>
