---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MasterIndexRail from '../../components/MasterIndexRail.astro';
import ProjectRow from '../../components/ProjectRow.astro';
import { allProjects, projectCategories } from '../../data/community-preview';
import { withBase } from '../../lib/labels';

const sortedCategories = [...projectCategories].sort((a, b) => a.name.localeCompare(b.name));
const projectIndex = [
  {
    items: sortedCategories.map((category) => ({
      label: category.name,
      href: withBase(`/projects/types/${category.slug}/`),
      count: category.projectCount,
    })),
  },
];
---

<BaseLayout
  title="Projects — CURATIONS.DEV"
  description="Explore public Projects, working plans, and the conversations helping builders improve them."
  communityPreview
  noindex
>
  <a class="community-page-back" href={withBase('/')}>← Community Board</a>

  <header class="discovery-header">
    <div>
      <p class="discovery-eyebrow">What people are building</p>
      <h1>Projects</h1>
      <p>Public Projects and the conversations helping builders improve them.</p>
    </div>
    <a class="community-action community-action-primary" href={withBase('/projects/new/')}>
      Share a project
    </a>
  </header>

  <nav class="discovery-tabs" aria-label="Project views">
    <a class="is-active" href="#active-projects">Active</a>
    <a href="#active-projects">New</a>
    <a href="#active-projects">Top</a>
    <a href="#active-projects">Needs feedback</a>
    <a href="#active-projects">Recently improved</a>
  </nav>

  <div class="board-home-layout discovery-layout">
    <main class="board-stack-column">
      <section id="active-projects" class="board-list-section">
        <header class="board-list-heading">
          <h2>Active Project conversations</h2>
          <span>sorted by recent discussion</span>
        </header>
        <div class="project-list">
          {allProjects.map((project) => <ProjectRow project={project} />)}
        </div>
      </section>

      <section class="board-list-section board-list-section-all">
        <header class="board-list-heading">
          <h2>Browse by Project type</h2>
          <span>alphabetical index</span>
        </header>
        <div class="discovery-index-list">
          {
            sortedCategories.map((category) => (
              <a
                class="discovery-index-row"
                href={withBase(`/projects/types/${category.slug}/`)}
              >
                <span>
                  <strong>{category.name}</strong>
                  <small>{category.description}</small>
                </span>
                <span class="discovery-index-metrics">
                  {category.projectCount} projects · {category.activityCount} conversations
                </span>
              </a>
            ))
          }
        </div>
      </section>
    </main>

    <MasterIndexRail title="Project types" sections={projectIndex} />
  </div>
</BaseLayout>
