---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MasterIndexRail from '../../components/MasterIndexRail.astro';
import ShowcaseRow from '../../components/ShowcaseRow.astro';
import { showcaseFixtures } from '../../data/member-showcase-preview';
import { stackFixtures } from '../../data/community-preview';
import { withBase } from '../../lib/labels';

const stackIndex = [
  ...new Set(showcaseFixtures.flatMap((showcase) => showcase.stackSlugs)),
]
  .map((slug) => stackFixtures[slug])
  .sort((a, b) => a.name.localeCompare(b.name))
  .map((stack) => ({
    label: stack.name,
    href: withBase(`/stacks/tools/${stack.slug}/`),
    count: showcaseFixtures.filter((showcase) => showcase.stackSlugs.includes(stack.slug)).length,
  }));

const showcaseIndex = [
  {
    title: 'Review modes',
    items: [
      { label: 'Discussion', href: '#showcase-conversations', count: showcaseFixtures.length },
      {
        label: 'Open for Roast',
        href: '#showcase-conversations',
        count: showcaseFixtures.filter((showcase) => showcase.roastOpen).length,
      },
      {
        label: 'Roasted',
        href: '#showcase-conversations',
        count: showcaseFixtures.filter((showcase) => showcase.roastCount > 0).length,
      },
    ],
  },
  { title: 'Stacks in Showcases', items: stackIndex },
];
---

<BaseLayout
  title="PRD Showcase - CURATIONS.DEV"
  description="Public product plans shared for discussion, self-promotion, and accountable critique."
  communityPreview
  noindex
>
  <a class="community-page-back" href={withBase('/')}>← Community Board</a>

  <header class="discovery-header">
    <div>
      <p class="discovery-eyebrow">Public product plans</p>
      <h1>PRD Showcase</h1>
      <p>
        Share what you are planning, explain its purpose, and invite discussion
        without entering the full Project loop first.
      </p>
      <p class="discovery-count">
        Illustrative fixture · structured self-promotion · source-linked
      </p>
    </div>
    <a class="community-action community-action-primary" href={withBase('/showcase/new/')}>
      Share your PRD
    </a>
  </header>

  <nav class="discovery-tabs" aria-label="Showcase views">
    <a class="is-active" href="#showcase-conversations">Active</a>
    <a href="#showcase-conversations">New</a>
    <a href="#showcase-conversations">Open for Roast</a>
    <a href="#showcase-conversations">Roasted</a>
    <a href="#showcase-conversations">Recently revised</a>
  </nav>

  <div class="board-home-layout discovery-layout">
    <main class="board-stack-column">
      <section id="showcase-conversations" class="board-list-section">
        <header class="board-list-heading">
          <h2>Active PRD conversations</h2>
          <span>purpose first · promotion with context</span>
        </header>
        <div class="project-list">
          {showcaseFixtures.map((showcase) => <ShowcaseRow showcase={showcase} />)}
        </div>
      </section>
    </main>

    <MasterIndexRail title="Showcase index" sections={showcaseIndex} />
  </div>
</BaseLayout>
