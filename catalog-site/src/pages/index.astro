---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Curations.DEV - Tier A Run Records">
  <div class="max-w-4xl mx-auto py-12 px-6">
    <header class="mb-12">
      <h1 class="text-4xl font-bold font-mono tracking-tight text-neutral-900 dark:text-white mb-4">Curations.DEV // Tier A Records</h1>
      <p class="text-xl text-neutral-600 dark:text-neutral-400">
        Deterministic, single-player hygiene outputs. You execute the audit securely in your own GitHub Actions environment. We display the badge. No AI required for entry.
      </p>
    </header>

    <div class="bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-600 dark:border-blue-400 p-6 rounded-r-md mb-12 shadow-sm">
      <h2 class="text-lg font-bold text-blue-900 dark:text-blue-200 mb-2">Build Your Own Compute (BYOC)</h2>
      <p class="text-blue-800 dark:text-blue-300 font-mono text-sm">
        Our Tier A audits run securely on your billing tab. Your code never hits an opaque server.
        See <a href="https://github.com/curationsx/yolo/blob/main/docs/ROADMAP.md" class="underline hover:text-blue-600">ROADMAP.md</a> for our strict v0.1 scope boundary.
      </p>
    </div>

    <!-- Tier A Badge Prototype -->
    <div class="bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg overflow-hidden shadow-sm">
      <div class="px-6 py-4 bg-neutral-50 dark:bg-neutral-900 border-b border-neutral-200 dark:border-neutral-700 flex justify-between items-center">
        <h3 class="font-bold flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-emerald-500"></span> 
          yolo / hygiene
        </h3>
        <span class="text-sm font-mono bg-neutral-200 dark:bg-neutral-700 px-2 py-1 rounded text-neutral-700 dark:text-neutral-300">Run ID: 0bc-9d7a</span>
      </div>
      <div class="p-6">
        <ul class="space-y-3 font-mono text-sm">
          <li class="flex items-start gap-3">
            <span class="text-emerald-600 dark:text-emerald-400">✓</span> 
            <span class="text-neutral-800 dark:text-neutral-200">gitignore_present - .gitignore covers common secret patterns</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-emerald-600 dark:text-emerald-400">✓</span> 
            <span class="text-neutral-800 dark:text-neutral-200">sensitive_filenames - No sensitive filenames committed</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-emerald-600 dark:text-emerald-400">✓</span> 
            <span class="text-neutral-800 dark:text-neutral-200">readme_nontrivial - README is non-trivial</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-emerald-600 dark:text-emerald-400">✓</span> 
            <span class="text-neutral-800 dark:text-neutral-200">licence_present - Licence file present</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>
