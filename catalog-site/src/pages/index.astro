---
/**
 * Homepage — public run-record display (Lane B).
 *
 * Renders only real run-records loaded from docs/audits/run-records/.
 * If none exist, an honest empty state renders — never a placeholder row.
 * Falsifying proof for this page: remove the JSON records and rebuild;
 * any fabricated row that still renders is a Lane B failure.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import RunRecordRow from '../components/RunRecordRow.astro';
import { loadRunRecords, SELF_AUDIT_REPO } from '../data/run-records';

const records = loadRunRecords();
const recordsUrl = `https://github.com/${SELF_AUDIT_REPO}/tree/main/docs/audits/run-records`;
const workflowUrl = `https://github.com/${SELF_AUDIT_REPO}/blob/main/.github/workflows/hygiene-audit-reusable.yml`;
const schemaVersion = records[0]?.script_versions?.run_record_schema;
---

<BaseLayout
  title="CURATIONS.DEV — Tier A run records"
  description="Public Tier A hygiene run records. Deterministic audits executed in your own GitHub Actions — real evidence, no mocks."
>
  <section class="run-records-page">
    <header class="run-records-header">
      <h1>Tier A run records</h1>
      <p class="run-records-tagline">
        Deterministic hygiene audits. You run them in your own GitHub Actions —
        your compute, your billing, your evidence. We display the record.
      </p>
    </header>

    <aside class="run-records-byoc">
      <h2>Bring your own compute</h2>
      <p>
        Tier A audits execute in your Actions environment from
        a <a href={workflowUrl}>pinned reusable workflow</a>. Your code never
        touches our servers. Scope is deliberately narrow — see
        the <a href={`https://github.com/${SELF_AUDIT_REPO}/blob/main/docs/ROADMAP.md`}>v0.1 cut-list</a>.
      </p>
    </aside>

    <section class="run-records-list" aria-label="Public run records">
      <h2 class="run-records-list-title">Public records</h2>

      {records.length === 0 ? (
        <div class="run-records-empty">
          <p><strong>No public run records yet.</strong></p>
          <p>
            Run the Tier A audit in your own Actions via the
            <a href={workflowUrl}>reusable workflow</a>, then publish the
            run-record. Records rendered here are loaded from
            <a href={recordsUrl}>docs/audits/run-records</a> — nothing is mocked.
          </p>
        </div>
      ) : (
        <>
          {records.map((record, index) => (
            <RunRecordRow record={record} latest={index === 0} />
          ))}
          <p class="run-records-provenance">
            {records.length} records · source <a href={recordsUrl}>docs/audits/run-records</a>{schemaVersion ? ` · run_record_schema ${schemaVersion}` : ''}
          </p>
        </>
      )}
    </section>
  </section>
</BaseLayout>
