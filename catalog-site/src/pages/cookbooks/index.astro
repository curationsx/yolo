---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  COOKBOOK_CATEGORY_LABELS,
  STACKS,
  cookbookPresentation,
  stackDefinition,
  versionLabel,
  type CookbookCategory,
  type CookbookData,
} from '../../lib/cookbooks';
import { REPO_URL } from '../../lib/labels';

const categoryOrder: CookbookCategory[] = [
  'engineering',
  'research',
  'operations',
  'safety',
];
const cookbooks = (await getCollection('cookbooks'))
  .map((entry) => entry.data as CookbookData)
  .sort((a, b) => categoryOrder.indexOf(a.category) - categoryOrder.indexOf(b.category));
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const defaultStack = stackDefinition('ollama');
const apiBase = import.meta.env.PUBLIC_AGENT_API ?? '';
---

<BaseLayout
  title="Cookbooks — CURATIONS.DEV"
  description="Stack-aware, schema-validated Human × AI cookbooks that run through the user's GitHub Copilot plan or terminal."
>
  <div class="board-page-back">
    <a href={basePath || '/'}>&larr; all stacks</a>
    <span>The Board / Cookbooks</span>
  </div>

  <section class="cookbooks-hero">
    <div>
      <span class="board-eyebrow">Community playbook</span>
      <h1>Community cookbooks</h1>
    </div>
    <p>
      Prompts as code: schema-validated, versioned, and tailored to the stack
      you already use. Run through your GitHub Copilot plan here or move the
      same contract into your terminal.
    </p>
  </section>

  <aside class="cookbook-boundary">
    <strong>User-funded execution</strong>
    <span>
      Use My Copilot charges your GitHub plan with zero repository tools. Run in
      My Terminal keeps the prompt and response entirely on your machine.
    </span>
  </aside>

  <div class="cookbook-toolbar">
    <div class="cookbook-filters" role="group" aria-label="Filter cookbooks by category">
      <button type="button" data-cookbook-filter="all" aria-pressed="true">All</button>
      {
        categoryOrder.map((category) => (
          <button type="button" data-cookbook-filter={category} aria-pressed="false">
            {COOKBOOK_CATEGORY_LABELS[category]}
          </button>
        ))
      }
    </div>
    <span class="cookbook-count" data-cookbook-count aria-live="polite">
      {cookbooks.length} cookbooks
    </span>
  </div>

  <section class="cookbook-grid" aria-label="Cookbook inventory">
    {
      cookbooks.map((cookbook) => {
        const presentation = cookbookPresentation(cookbook.id);
        const initialStrong = cookbook.strong_fit.includes('ollama');
        return (
          <article
            class="cookbook-card"
            data-cookbook-card
            data-cookbook-id={cookbook.id}
            data-cookbook-title={cookbook.title}
            data-cookbook-version={cookbook.version}
            data-cookbook-category={cookbook.category}
            data-base-path={basePath}
            data-strong-fit={JSON.stringify(cookbook.strong_fit)}
            data-code={JSON.stringify(presentation.code)}
            data-fit-note={JSON.stringify(presentation.fitNote)}
            style={`--cookbook-accent: ${presentation.accent}; --cookbook-stack: ${defaultStack.color};`}
          >
            <div class="cookbook-card-main">
              <div class="cookbook-glyph" aria-hidden="true">{presentation.glyph}</div>
              <div>
                <div class="cookbook-meta">
                  <span class="cookbook-category">{COOKBOOK_CATEGORY_LABELS[cookbook.category]}</span>
                  <span>{versionLabel(cookbook.version)}</span>
                  <span>{cookbook.release_status}</span>
                </div>
                <h2>{cookbook.title}</h2>
                <p>{cookbook.description}</p>
                <p class="cookbook-source">
                  Source:
                  <a href={`${REPO_URL}/blob/main/${cookbook.source_prompt}`}>
                    {cookbook.source_prompt_id}@{cookbook.source_version}
                  </a>
                  <span>{cookbook.source_status}</span>
                </p>
              </div>
            </div>

            <div class="cookbook-tailoring">
              <label>
                Tailor to stack
                <span class="stack-select-shell">
                  <span class="stack-mark" data-stack-mark aria-label={defaultStack.name}>
                    {defaultStack.glyph}
                  </span>
                  <select data-stack-select aria-label={`Tailor ${cookbook.title} to a stack`}>
                    {STACKS.map((stack) => <option value={stack.id}>{stack.name}</option>)}
                  </select>
                </span>
              </label>
              <pre class="cookbook-code" aria-label="Tailored stack example"><code data-tailored-code>
                {presentation.code.ollama.map((line) => <span>{line}</span>)}
              </code></pre>
            </div>

            <div class="cookbook-fit">
              <div class="cookbook-agent-avatar" aria-hidden="true">AI</div>
              <div>
                <div class="cookbook-agent-line">
                  <strong>Steward preview</strong>
                  <span class="badge badge-ai">AI · DESIGN PROTOTYPE</span>
                  <span class:list={['fit-badge', !initialStrong && 'is-partial']} data-fit-badge>
                    {initialStrong ? 'STRONG FIT' : 'PARTIAL FIT'}
                  </span>
                </div>
                <p data-fit-note>{presentation.fitNote.ollama}</p>
                <a data-stack-board href={`${basePath}/software/ollama/#company-board`}>
                  Ask the Ollama steward on its board -&gt;
                </a>
              </div>
            </div>

            <button type="button" class="cookbook-handoff" data-handoff-open>
              Choose how to run -&gt;
            </button>
          </article>
        );
      })
    }
  </section>

  <section class="cookbook-distillation">
    <div>
      <span class="board-eyebrow">Distillation loop</span>
      <h2>Use it. Challenge it. Improve it.</h2>
    </div>
    <p>
      Board discussions remain public and GitHub-attributed. Useful tailoring
      evidence can graduate into a reviewed cookbook revision through the
      repository; no agent promotes its own output.
    </p>
  </section>

  <dialog
    class="handoff-dialog"
    data-handoff-dialog
    data-api={apiBase}
    aria-labelledby="handoff-title"
  >
    <div class="handoff-dialog-inner">
      <form method="dialog">
        <button class="handoff-close" type="submit" aria-label="Close handoff dialog">x</button>
      </form>
      <span class="editorial-eyebrow">One cookbook · two user-owned paths</span>
      <h2 id="handoff-title" data-handoff-title>Cookbook</h2>
      <p class="handoff-meta" data-handoff-meta></p>

      <div class="handoff-mode-switch" role="tablist" aria-label="Choose how to run">
        <button
          type="button"
          role="tab"
          data-handoff-mode="copilot"
          aria-selected="true"
        >
          <strong>1 · Use My Copilot</strong>
          <span>Run here · billed to your GitHub plan</span>
        </button>
        <button
          type="button"
          role="tab"
          data-handoff-mode="terminal"
          aria-selected="false"
        >
          <strong>2 · Run in My Terminal</strong>
          <span>Local prompt · CURATIONS cannot see the run</span>
        </button>
      </div>

      <section class="handoff-panel" data-handoff-panel="copilot">
        <div class="handoff-trust handoff-trust-copilot">
          <strong>Your Copilot plan. One authorization. Zero tools.</strong>
          <p>
            CURATIONS sends this versioned cookbook and receives the response
            shown below. The encrypted GitHub token expires within 10 minutes,
            is consumed once, and cannot access repositories, files, shell,
            MCP, skills, or plugins.
          </p>
        </div>

        <label class="handoff-focus">
          Optional focus for this run
          <textarea
            rows="4"
            maxlength="2000"
            data-copilot-focus
            placeholder="What should your Copilot pressure-test, clarify, or decide?"
          ></textarea>
        </label>

        <div class="handoff-actions">
          <button type="button" class="btn btn-primary" data-copilot-connect>
            Connect my GitHub Copilot
          </button>
          <button type="button" class="btn btn-secondary" data-copilot-run hidden>
            Run with my Copilot
          </button>
          <span data-copilot-status role="status" aria-live="polite"></span>
        </div>

        <article class="copilot-response" data-copilot-response-root hidden>
          <div class="copilot-response-meta" data-copilot-response-meta></div>
          <div class="copilot-response-text" data-copilot-response></div>
        </article>
      </section>

      <section class="handoff-panel" data-handoff-panel="terminal" hidden>
        <div class="handoff-trust">
          <strong>Your terminal. Your account. Your private run.</strong>
          <p>
            The command downloads a plain-text cookbook contract, then opens an
            interactive Copilot CLI session. CURATIONSX does not receive the
            terminal prompt or its output.
          </p>
        </div>

        <pre class="handoff-command"><code data-handoff-command></code></pre>

        <div class="handoff-actions">
          <button type="button" class="btn btn-primary" data-handoff-copy>Copy command</button>
          <a data-handoff-prompt target="_blank" rel="noopener">Inspect prompt first</a>
          <span data-handoff-status role="status" aria-live="polite"></span>
        </div>

        <details class="handoff-caveat">
          <summary>What is enforced?</summary>
          <p>
            Copilot CLI v1.0.70 supports the interactive <code>-i</code> handoff.
            It does not provide native <code>--checkpoint</code>,
            <code>--budget</code>, or <code>--max-requests</code> flags. Those
            limits travel visibly inside the cookbook contract; the CLI must not
            pretend they are native hard limits.
          </p>
        </details>
      </section>
    </div>
  </dialog>
</BaseLayout>

<script>
  import { initCookbooks } from '../../components/Cookbooks';
  initCookbooks();
</script>
