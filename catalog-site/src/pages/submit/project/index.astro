---
/**
 * Builder Onboarding UI (Gate 3) 
 * 
 * Re-aligned to the Visual Oracle "brutalist" style.
 * Uses WikiLayout.astro to ensure 2px borders, instrument serif headings,
 * and high-signal, stranger-friendly copy.
 */
import WikiLayout from '../../../layouts/WikiLayout.astro';
import WikiCallout from '../../../components/WikiCallout.astro';

const apiBase = import.meta.env.PUBLIC_AGENT_API ?? '';
---

<WikiLayout title="Validate Your Workflow">
  <h1>Validate Your Workflow</h1>
  <p>Submit your public repository. Discover missing skills, see how your tech stack compares against community trends, and receive high-signal insights. The validation runs in <em>your</em> GitHub Actions — your compute, your billing, your evidence. </p>
  
  <WikiCallout title="What we will never do">
    We never ask for write access to your repository, never run your code on our servers, and discard the GitHub token after sign-in. The generated workflow is pinned to an immutable commit — nothing changes underneath you.
  </WikiCallout>

  <section class="audit-intake" data-audit-intake data-api={apiBase} style="margin-top: 3rem;">
    
    <!-- Step 1 -->
    <div class="audit-intake-step" data-step-auth style="border: 2px solid var(--near-black); padding: 2rem; margin-bottom: 2rem; background: #fff; box-shadow: var(--shadow-sm);">
      <h2 style="margin-top: 0; border-bottom: none; padding-bottom: 0;">1 · Identity</h2>
      <p class="audit-intake-status" data-auth-state style="font-family: var(--font-mono); font-size: 0.9rem;">Checking GitHub identity…</p>
      <button type="button" class="audit-intake-button" data-sign-in hidden style="background: var(--near-black); color: var(--seasalt-white); border: 2px solid var(--near-black); padding: 0.8rem 1.5rem; font-family: var(--font-mono); font-weight: bold; cursor: pointer; box-shadow: 2px 2px 0 var(--coral-red);">
        [ Sign in with GitHub ]
      </button>
    </div>

    <!-- Step 2 -->
    <form class="audit-intake-step" data-step-repo hidden style="border: 2px solid var(--near-black); padding: 2rem; margin-bottom: 2rem; background: #fff; box-shadow: var(--shadow-sm);">
      <h2 style="margin-top: 0; border-bottom: none; padding-bottom: 0;">2 · Your Repository</h2>
      <label class="audit-intake-label" for="repository-url" style="display: block; margin-bottom: 0.5rem; font-family: var(--font-mono); font-weight: bold;">
        Public repository you own:
      </label>
      <div class="audit-intake-controls" style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <input
          id="repository-url"
          name="repository-url"
          type="url"
          class="audit-intake-input"
          placeholder="https://github.com/you/your-repo"
          autocomplete="off"
          spellcheck="false"
          required
          style="flex: 1; padding: 0.8rem; border: 2px solid var(--near-black); font-family: var(--font-mono); box-shadow: inset 2px 2px 0 rgba(0,0,0,0.05); min-width: 250px;"
        />
        <button type="submit" class="audit-intake-button" data-check style="background: var(--near-black); color: var(--seasalt-white); border: 2px solid var(--near-black); padding: 0.8rem 1.5rem; font-family: var(--font-mono); font-weight: bold; cursor: pointer; box-shadow: 2px 2px 0 var(--coral-red);">
          [ Check Repository ]
        </button>
      </div>
      <p class="audit-intake-refusal" data-refusal role="alert" hidden style="margin-top: 1rem; color: var(--coral-red); font-family: var(--font-mono); font-weight: bold; border-left: 3px solid var(--coral-red); padding-left: 1rem;"></p>
    </form>

    <!-- Step 3 -->
    <div class="audit-intake-step" data-step-workflow hidden style="border: 2px solid var(--near-black); padding: 2rem; margin-bottom: 2rem; background: #fff; box-shadow: var(--shadow-sm);">
      <h2 style="margin-top: 0; border-bottom: none; padding-bottom: 0;">3 · Commit the Pinned Workflow</h2>
      <p class="audit-intake-summary" data-summary style="font-family: var(--font-mono); font-weight: bold; padding: 1rem; background: var(--seasalt-white); border: 2px solid var(--near-black);"></p>
      
      <p class="audit-intake-path" style="margin-top: 1.5rem;">
        Create <code data-workflow-path style="background: var(--neon-yellow);"></code> with:
      </p>
      
      <!-- Overrides WikiLayout pre styles to keep them tight inside the box -->
      <pre class="audit-intake-yaml" style="margin-top: 0;"><code data-workflow-yaml></code></pre>
      
      <ol class="audit-intake-steps" data-next-steps style="font-family: var(--font-sans); line-height: 1.5; margin-top: 1.5rem;"></ol>
      
      <div class="audit-intake-links" style="margin-top: 2rem; border-top: 2px solid var(--near-black); padding-top: 1rem;">
        <a data-guide-link href="/stranger-guide/" style="color: var(--coral-red); font-family: var(--font-mono); font-weight: bold; text-decoration: none; margin-right: 1rem;">→ Read Stranger Guide</a>
        <a href="/" style="color: var(--near-black); font-family: var(--font-mono); font-weight: bold; text-decoration: none;">→ View Public Run Records</a>
      </div>
    </div>
  </section>
</WikiLayout>

<script>
  import {
    authHeaders,
    beginGithubSignIn,
    broadcastAuth,
    consumeOAuthResult,
    currentUser,
  } from '../../../lib/browser-auth';

  const root = document.querySelector<HTMLElement>('[data-audit-intake]')!;
  const api = root.dataset.api ?? '';
  const authState = root.querySelector<HTMLElement>('[data-auth-state]')!;
  const signIn = root.querySelector<HTMLButtonElement>('[data-sign-in]')!;
  const repoStep = root.querySelector<HTMLFormElement>('[data-step-repo]')!;
  const workflowStep = root.querySelector<HTMLElement>('[data-step-workflow]')!;
  const input = root.querySelector<HTMLInputElement>('#repository-url')!;
  const check = root.querySelector<HTMLButtonElement>('[data-check]')!;
  const refusal = root.querySelector<HTMLElement>('[data-refusal]')!;
  const summary = root.querySelector<HTMLElement>('[data-summary]')!;
  const workflowPath = root.querySelector<HTMLElement>('[data-workflow-path]')!;
  const workflowYaml = root.querySelector<HTMLElement>('[data-workflow-yaml]')!;
  const nextSteps = root.querySelector<HTMLOListElement>('[data-next-steps]')!;
  const guideLink = root.querySelector<HTMLAnchorElement>('[data-guide-link]')!;

  consumeOAuthResult();

  const renderSignedOut = (): void => {
    authState.textContent = 'Sign in with GitHub to begin. We request read:user only.';
    signIn.hidden = false;
    repoStep.hidden = true;
    workflowStep.hidden = true;
  };

  const renderSignedIn = (login: string): void => {
    authState.textContent = `Signed in as @${login}.`;
    signIn.hidden = true;
    repoStep.hidden = false;
  };

  signIn.addEventListener('click', () => beginGithubSignIn(api, '/submit/project/'));

  void (async () => {
    const user = await currentUser(api);
    broadcastAuth(user);
    if (user) renderSignedIn(user.login);
    else renderSignedOut();
  })();

  repoStep.addEventListener('submit', async (event) => {
    event.preventDefault();
    refusal.hidden = true;
    workflowStep.hidden = true;
    check.disabled = true;
    check.textContent = 'Checking…';
    try {
      const response = await fetch(`${api}/api/audit/intake`, {
        method: 'POST',
        headers: { 'content-type': 'application/json', ...authHeaders() },
        body: JSON.stringify({ repository_url: input.value.trim() }),
      });
      const body = await response.json();
      if (!response.ok) {
        refusal.textContent = body.error ?? 'The repository could not be checked.';
        refusal.hidden = false;
        return;
      }
      summary.textContent =
        `${body.repository.owner}/${body.repository.name} · ` +
        `${body.repository.default_branch} @ ${body.commit_sha.slice(0, 12)} · ` +
        `audit pinned to curationsx/yolo@${body.audit_ref.slice(0, 12)}`;
      workflowPath.textContent = body.workflow_path;
      workflowYaml.textContent = body.workflow_yaml;
      nextSteps.replaceChildren(
        ...body.next_steps.map((step: string) => {
          const item = document.createElement('li');
          item.textContent = step;
          return item;
        }),
      );
      guideLink.href = body.guide_url;
      workflowStep.hidden = false;
    } catch {
      refusal.textContent =
        'The audit service could not be reached. Nothing was submitted — try again shortly.';
      refusal.hidden = false;
    } finally {
      check.disabled = false;
      check.textContent = '[ Check Repository ]';
    }
  });
</script>
