---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CapabilityStamp from '../../../components/CapabilityStamp.astro';
import MemberPrivateGate from '../../../components/MemberPrivateGate.astro';
import StackPill from '../../../components/StackPill.astro';
import { showcaseFixture } from '../../../data/member-showcase-preview';
import { withBase } from '../../../lib/labels';

const fixtureEnabled =
  import.meta.env.DEV && import.meta.env.PUBLIC_MEMBER_FIXTURES === 'true';
---

<BaseLayout
  title="Skill Request preview - CURATIONS.DEV"
  description="Fixture-only preview of an anchored, member-started Skill Request."
  communityPreview
  noindex
>
  <a class="community-page-back" href={withBase('/skills/')}>← Find Skills</a>

  <header class="discovery-header project-builder-header">
    <div>
      <p class="discovery-eyebrow">No reviewed match</p>
      <h1>Start a Skill Request</h1>
      <p>
        Anchor one human question to an approved PRD revision. CURATIONS never
        auto-posts a request or substitutes an unreviewed Skill.
      </p>
    </div>
    <span class="project-builder-status">No post · no fetch · no model</span>
  </header>

  <form class="member-settings-form skill-request-form" data-skill-request-fixture>
    <fieldset>
      <legend>Exact public preview</legend>
      <div class="field-grid">
        <label>
          Subject
          <input value={showcaseFixture.title} disabled />
        </label>
        <label>
          PRD revision
          <input value={showcaseFixture.sourceRevision} disabled />
        </label>
        <label>
          Help intent
          <select name="help_intent">
            <option selected>Grow</option>
            <option>Plan</option>
            <option>Review</option>
            <option>Ship</option>
          </select>
        </label>
        <label>
          Host constraint
          <select name="host">
            <option selected>GitHub Copilot CLI</option>
            <option>Manual checklist</option>
          </select>
        </label>
        <label class="field-span">
          Human question
          <textarea name="question" rows="3" required>Which reviewed Skill could help this PRD prepare a launch without requiring repository or deployment access?</textarea>
        </label>
      </div>

      <section class="skill-request-preview">
        <header>
          <CapabilityStamp kind="no-match" />
          <strong>Anchored to one approved PRD revision</strong>
        </header>
        <p>
          <span data-skill-request-question>
            Which reviewed Skill could help this PRD prepare a launch without
            requiring repository or deployment access?
          </span>
        </p>
        <div class="project-context">
          <StackPill slug="astro" />
          <StackPill slug="typescript" />
          <StackPill slug="github" />
        </div>
        <small>
          Inherited: Developer Tools · fixture PRD · no repository read · no hosted AI ·
          intent <span data-skill-request-intent>Grow</span> ·
          host <span data-skill-request-host>GitHub Copilot CLI</span>
        </small>
      </section>

    </fieldset>

    <MemberPrivateGate fixtureEnabled={fixtureEnabled}>
      {
        fixtureEnabled ? (
          <>
            <label class="check-row showcase-confirmation">
              <input type="checkbox" name="watch_matches" />
              Watch this approved context for future reviewed matches.
            </label>
            <label class="check-row showcase-confirmation">
              <input type="checkbox" name="request_consent" required />
              I reviewed this exact fixture preview and choose to send it to maintainer review.
            </label>
            <div class="submission-nav">
              <a class="community-action" href={withBase('/me/matches/?fixture_auth=1')}>
                Back to matches
              </a>
              <button class="community-action community-action-primary" type="submit">
                Send Skill Request
              </button>
            </div>
            <p class="field-help" data-skill-request-status aria-live="polite">
              Fixture only. No thread, Watch, or notification exists.
            </p>
          </>
        ) : (
          <section class="member-workspace-unavailable">
            <p class="discovery-eyebrow">Authenticated shell only</p>
            <h1>Skill Request persistence is not enabled.</h1>
            <p>No request, Watch, or member context is embedded in production HTML.</p>
          </section>
        )
      }
    </MemberPrivateGate>
  </form>
</BaseLayout>

<script>
  for (const form of document.querySelectorAll<HTMLFormElement>('[data-skill-request-fixture]')) {
    const question = form.elements.namedItem('question');
    const intent = form.elements.namedItem('help_intent');
    const host = form.elements.namedItem('host');
    const previewQuestion = form.querySelector<HTMLElement>('[data-skill-request-question]');
    const previewIntent = form.querySelector<HTMLElement>('[data-skill-request-intent]');
    const previewHost = form.querySelector<HTMLElement>('[data-skill-request-host]');

    const renderPreview = (): void => {
      if (question instanceof HTMLTextAreaElement && previewQuestion) {
        previewQuestion.textContent = question.value.trim();
      }
      if (intent instanceof HTMLSelectElement && previewIntent) {
        previewIntent.textContent = intent.value;
      }
      if (host instanceof HTMLSelectElement && previewHost) {
        previewHost.textContent = host.value;
      }
    };

    form.addEventListener('input', (event) => {
      renderPreview();
      if (event.target === question || event.target === intent || event.target === host) {
        const consent = form.elements.namedItem('request_consent');
        if (consent instanceof HTMLInputElement) consent.checked = false;
      }
    });
    form.addEventListener('change', renderPreview);
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const consent = form.elements.namedItem('request_consent');
      if (!(consent instanceof HTMLInputElement) || !consent.checked) return;
      if (!form.reportValidity()) return;
      const status = form.querySelector<HTMLElement>('[data-skill-request-status]');
      if (status) {
        status.textContent =
          'Pending review · fixture complete. No thread, Watch, fetch, or model call occurred.';
      }
    });
    renderPreview();
  }
</script>
