{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/curationsx/yolo/schemas/run-record.schema.json",
  "title": "Audit run record",
  "description": "Validates deterministic and generative audit run-records emitted by Curations.DEV scripts. Schema version 1.2.0 — adds optional moonshot-dataset fields (categories, suggestion_plan_ref, grounding) on top of 1.1.0's measurement fields; every 1.1.0 record remains valid.",
  "type": "object",
  "required": [
    "run_id",
    "repo_fingerprint",
    "matrix_cells",
    "findings",
    "tokens_spent",
    "script_versions",
    "previous_run",
    "cohort_ref",
    "created_at",
    "execution_context",
    "dispute",
    "correction",
    "wall_clock_seconds",
    "github_api_requests",
    "files_inspected",
    "bytes_inspected",
    "checks_passed",
    "checks_total",
    "ruleset_version",
    "commit_sha"
  ],
  "additionalProperties": false,
  "$defs": {
    "uuidOrNull": {
      "oneOf": [
        {
          "type": "string",
          "format": "uuid"
        },
        {
          "type": "null"
        }
      ]
    },
    "lineageEntry": {
      "type": "object",
      "required": ["run_id", "relation"],
      "additionalProperties": false,
      "properties": {
        "run_id": {
          "type": "string",
          "format": "uuid"
        },
        "relation": {
          "type": "string",
          "enum": ["disputes", "supersedes", "references"]
        }
      }
    },
    "finding": {
      "type": "object",
      "required": ["check_id", "passed", "artifact", "confidence", "detail", "severity"],
      "additionalProperties": false,
      "properties": {
        "check_id": {
          "type": "string",
          "minLength": 1
        },
        "passed": {
          "type": "boolean"
        },
        "artifact": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warn", "fail"]
        }
      }
    },
    "executionContext": {
      "type": "object",
      "required": ["model", "cli_version", "entitlement_type"],
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": ["string", "null"]
        },
        "cli_version": {
          "type": "string",
          "minLength": 1
        },
        "entitlement_type": {
          "type": ["string", "null"]
        }
      }
    },
    "dispute": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": ["status", "detail", "lineage"],
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["open", "under_review", "resolved", "rejected"]
            },
            "detail": {
              "type": "string",
              "minLength": 1
            },
            "lineage": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/lineageEntry"
              },
              "minItems": 1
            }
          }
        }
      ]
    },
    "correction": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": ["detail", "corrected_at", "lineage"],
          "additionalProperties": false,
          "properties": {
            "detail": {
              "type": "string",
              "minLength": 1
            },
            "corrected_at": {
              "type": "string",
              "format": "date-time"
            },
            "lineage": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/lineageEntry"
              },
              "minItems": 1
            }
          }
        }
      ]
    }
  },
  "properties": {
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "repo_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "matrix_cells": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      },
      "minItems": 1
    },
    "tokens_spent": {
      "type": "integer",
      "minimum": 0
    },
    "script_versions": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+$"
      },
      "minProperties": 1
    },
    "previous_run": {
      "$ref": "#/$defs/uuidOrNull"
    },
    "cohort_ref": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "badge_level": {
      "description": "Convenience label only — not required. Primary badge is derived from checks_passed/checks_total + ruleset_version.",
      "type": "string",
      "enum": ["gold", "silver", "bronze", "needs-work"]
    },
    "execution_context": {
      "$ref": "#/$defs/executionContext"
    },
    "dispute": {
      "$ref": "#/$defs/dispute"
    },
    "correction": {
      "$ref": "#/$defs/correction"
    },
    "wall_clock_seconds": {
      "description": "Total elapsed time from audit_repository entry to run-record write, in seconds.",
      "type": "number",
      "minimum": 0
    },
    "github_api_requests": {
      "description": "Number of GitHub API / git network operations during the run. 0 for local-path runs; 1 for remote-URL runs (git clone).",
      "type": "integer",
      "minimum": 0
    },
    "files_inspected": {
      "description": "Number of files the runner examined (tracked via repository_files()).",
      "type": "integer",
      "minimum": 0
    },
    "bytes_inspected": {
      "description": "Total bytes of tracked files in the repository tree.",
      "type": "integer",
      "minimum": 0
    },
    "checks_passed": {
      "description": "Number of individual checks that returned a passing result.",
      "type": "integer",
      "minimum": 0
    },
    "checks_total": {
      "description": "Total number of checks attempted. For hygiene/0.1.0 this is always 7.",
      "type": "integer",
      "minimum": 0
    },
    "ruleset_version": {
      "description": "Capability version that produced this record, e.g. 'hygiene/0.1.0'. Matches taxonomy/capabilities.yaml.",
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "description": "Immutable commit SHA the runner observed. Null for local non-git directories.",
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "categories": {
      "description": "Optional (schema 1.2.0) — category flags from taxonomy/categories.yaml. 'observed' ids are deterministically detected from repository markers; 'declared' ids are owner-stated at intake. The two are never merged (Evidence Registry rule: observation and declaration stay distinguishable).",
      "type": "object",
      "additionalProperties": false,
      "required": ["vocabulary_version", "observed"],
      "properties": {
        "vocabulary_version": {
          "type": "string",
          "minLength": 1
        },
        "observed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "declared": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "suggestion_plan_ref": {
      "description": "Optional (schema 1.2.0) — id of the suggestion-plan artifact this run responds to, when the run is a re-run after acting on a plan. Null/absent for organic runs. This field is what turns re-run deltas into intervention->outcome rows.",
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "grounding": {
      "description": "Optional (schema 1.2.0) — world-state provenance for any generated guidance associated with this run. Names the versioned grounding snapshot consulted, so every suggestion can cite what the world knew at that moment.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider", "snapshot_ref"],
          "properties": {
            "provider": {
              "type": "string",
              "minLength": 1
            },
            "snapshot_ref": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
